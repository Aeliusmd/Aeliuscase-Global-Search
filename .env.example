# Server-side only - NEVER add NEXT_PUBLIC_ prefix to these
API_BASE_URL=https://uatapi.aeliuscase.com
AI_SEARCH_PRIVATE_KEY_PEM=<backend-provided-private-key-pem>

RATE_LIMIT_PER_MIN=20

# OpenAI - used for AI-powered chat responses and guide search
OPENAI_API_KEY=sk-...your_openai_key_here
OPENAI_VECTOR_STORE_ID=vs_...your_vector_store_id

# Client-safe - used to build case detail links: {APP_BASE_URL}/dashboard/case-overview/{id}
NEXT_PUBLIC_APP_BASE_URL=https://uat.aeliuscase.com

# Comma-separated UAT parent origins (CORS + CSP frame-ancestors)
NEXT_PUBLIC_UAT_ORIGINS=https://uat.aeliuscase.com,http://localhost:3000

# MongoDB - sessions, rate limits, user-scoped chat history, and audit trail
MONGODB_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/?retryWrites=true&w=majority
MONGODB_DB=aeliuscase
